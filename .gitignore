# indexes are regenerated from source of truth
index/*.csv
index/*.json
index/*.duckdb
index/*.html
index/.cache/
eln/reports/

# raw / large-file directories — track structure, not contents
raw/**
!raw/README.md
!raw/.gitkeep
wiki/raw/**
!wiki/raw/README.md
!wiki/raw/.gitkeep
wiki/files/**
!wiki/files/.gitkeep

# editor / OS junk
.DS_Store
.idea/
.vscode/
*.swp
